# ── Required (at least one LLM key needed) ────────────────────────────────────
GEMINI_API_KEY=AIza...        # Primary LLM provider (Google Gemini)
OPENAI_API_KEY=sk-...         # Fallback LLM provider (OpenAI)
TAVILY_API_KEY=tvly-...

# ── Optional enrichment APIs (LLM fallback used if missing) ───────────────────
CLEARBIT_API_KEY=
APOLLO_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# ── Storage ──────────────────────────────────────────────────────────────────
# PostgreSQL (Railway, Supabase, etc.):
#   DATABASE_URL=postgresql://user:pass@host:5432/dbname
# SQLite (local dev):
#   DATABASE_URL=sqlite:///data/fello.db
# In-memory (no persistence):
#   DATABASE_URL=none
DATABASE_URL=sqlite:///data/fello.db

# ── Model & tuning ────────────────────────────────────────────────────────────
MODEL_NAME=gpt-4o-mini
GEMINI_MODEL_NAME=gemini-2.0-flash
TOOL_TIMEOUT_SECONDS=8
TOOL_MAX_RETRIES=3
CACHE_TTL_SECONDS=300
